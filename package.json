{
  "name": "pamp",
  "version": "0.1.0",
  "description": "PAMP - portable dev stack version manager and service control panel for Windows",
  "main": "main.js",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ui/input.css -o ui/styles.css",
    "watch:css": "npx @tailwindcss/cli -i ui/input.css -o ui/styles.css --watch",
    "start": "npm run build:css && electron .",
    "dist": "npm run build:css && electron-builder --win"
  },
  "build": {
    "appId": "com.pamp",
    "productName": "PAMP",
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "ui/**"
    ],
    "win": {
      "icon": "ui/logo.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "PAMP-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "PAMP-${version}-setup.exe"
    }
  },
  "author": "PAMP",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
